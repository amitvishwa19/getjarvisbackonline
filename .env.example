# JARVIS Environment Variables
# Copy this file to .env and fill in the values

# OpenRouter (LLM provider)
OPENROUTER_API_KEY=sk-or-...

# OpenClaw Gateway token (for internal API)
OPENCLAW_TOKEN=...

# Telegram (optional - if using Telegram bot)
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# Google Workspace (for gmail/calendar/drive)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...

# Here.Now (static site hosting)
HERENOW_API_KEY=...

# Vercel (optional - alternative hosting)
VERCEL_API_TOKEN=...

# Slack (for posting to channels)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...  # Only needed for Socket Mode

# Tavily (web search)
TAVILY_API_KEY=tvly-...

# Firecrawl (web scraping)
FIRECRAWL_API_KEY=fc-...

# Optional: GitHub remote for backup offsite (if using HTTPS instead of SSH)
# GIT_REPO=https://<token>@github.com/username/repo.git

# OpenClaw Gateway port (default: 18789)
OPENCLAW_GATEWAY_PORT=18789

# Log level (info, debug, warn, error)
OPENCLAW_LOG_LEVEL=info

# Allowed agents for spawn (comma-separated)
OPENCLAW_ALLOWED_AGENTS=*