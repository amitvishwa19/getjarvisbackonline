# OpenClaw JARVIS Environment Variables
# Copy this file to .env and fill in actual values.
# Never commit .env to version control.

# Required
OPENROUTER_API_KEY=your_openrouter_key_here
OPENCLAW_TOKEN=generate_via_openclaw_token_generate
TELEGRAM_BOT_TOKEN=from_botfather
TELEGRAM_CHAT_ID=your_chat_id
GIT_REPO=https://github.com/yourname/backup-repo.git

# Optional
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
GOOGLE_AI_STUDIO_KEY=...
OPENCLAW_ALLOWED_AGENTS=bumblebee,doctor-x
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_LOG_LEVEL=info
TAVILY_API_KEY=...
FIRECRAWL_API_KEY=...

# Google Workspace (for google-workspace skill)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...

# Here.Now deployment
HERENOW_API_KEY=...

# Vercel deployment
VERCEL_API_TOKEN=...